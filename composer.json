{
    "name": "platform5/sdk",
    "description": "PHP SDK for the Platform5 Developer API — send SMS, email, and more",
    "type": "library",
    "license": "MIT",
    "authors": [{"name": "nixoncode"}],
    "require": {
        "php": ">=8.2",
        "guzzlehttp/guzzle": "^7.0",
        "guzzlehttp/psr7": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Platform5\\Sdk\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Platform5\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
